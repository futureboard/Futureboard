{
  "name": "futureboard-studio-desktop",
  "version": "2026.5.28",
  "author": {
    "name": "Arizkami",
    "email": "arizkami@futureboard.studio"
  },
  "homepage": "https://github.com/arizkami/Futureboard",
  "main": "dist/main.js",
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "concurrently": "^9.0.0",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "rcedit": "^5.0.2",
    "typescript": "^6.0.3",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "org.futureboard.studio",
    "productName": "Futureboard Studio",
    "executableName": "Futureboard Studio",
    "copyright": "Copyright © ${author}",
    "publish": {
      "provider": "github",
      "owner": "arizkami",
      "repo": "Futureboard"
    },
    "afterPack": "scripts/after-pack.cjs",
    "asar": true,
    "asarUnpack": [],
    "compression": "maximum",
    "removePackageScripts": true,
    "removePackageKeywords": true,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "package.json",
      "!**/*.map",
      "!**/*.ts",
      "!**/*.tsbuildinfo"
    ],
    "extraResources": [
      {
        "from": "../shared",
        "to": "icons",
        "filter": [
          "app.png",
          "icon.ico",
          "icon.icns"
        ]
      },
      {
        "from": "assets",
        "to": "assets",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources",
        "to": ".",
        "filter": [
          "*.node",
          "*.dll",
          "*.dylib",
          "*.so",
          "*.exe"
        ]
      }
    ],
    "fileAssociations": [
      {
        "ext": "mochiproj",
        "name": "Futureboard Studio Project",
        "description": "Futureboard Studio Project File",
        "role": "Editor",
        "icon": "../shared/icon.ico"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "../shared/icon.ico",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "shortcutName": "Futureboard Studio",
      "installerIcon": "../shared/icon.ico",
      "uninstallerIcon": "../shared/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.music",
      "icon": "../shared/icon.icns",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "hardenedRuntime": false,
      "identity": null
    },
    "linux": {
      "maintainer": "Arizkami <arizkami@futureboard.studio>",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "executableName": "futureboard-studio",
      "category": "AudioVideo;Audio;Music",
      "icon": "../shared/app.png",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "desktop": {
        "entry": {
          "Name": "Futureboard Studio",
          "Comment": "Digital Audio Workstation",
          "Categories": "AudioVideo;Audio;Music;",
          "StartupWMClass": "futureboard-studio"
        }
      }
    },
    "deb": {
      "priority": "optional",
      "packageCategory": "sound",
      "depends": [
        "libgtk-3-0",
        "libnotify4",
        "libnss3",
        "libxss1",
        "libxtst6",
        "xdg-utils",
        "libatspi2.0-0",
        "libuuid1",
        "libasound2"
      ]
    }
  },
  "description": "Futureboard Studio",
  "private": true,
  "scripts": {
    "build": "bun scripts/sync-shared-menu.mjs && tsc -p .",
    "sync:shared-menu": "bun scripts/sync-shared-menu.mjs",
    "dev": "concurrently -k -n tsc,electron -c blue,magenta \"tsc -p . --watch\" \"wait-on dist/main.js && electron .\"",
    "start": "electron .",
    "build:native:audio": "cd ../../crates/SphereDirectAudioEngine && cargo build --release --lib --features napi && node ../../apps/electron/scripts/copy-native-audio.mjs",
    "build:native:audio:debug": "cd ../../crates/SphereDirectAudioEngine && cargo build --lib --features napi && node ../../apps/electron/scripts/copy-native-audio.mjs --debug",
    "build:native:pluginhost": "node scripts/build-plugin-host.mjs && node scripts/copy-plugin-host.mjs",
    "build:native:pluginhost:debug": "node scripts/build-plugin-host.mjs --debug && node scripts/copy-plugin-host.mjs --debug",
    "build:renderer": "bun run --cwd ../web build:electron",
    "copy:renderer": "node scripts/copy-renderer.cjs",
    "build:all": "bun run build:native:audio && bun run build:native:pluginhost && bun run build:renderer && bun run build && bun run copy:renderer",
    "pack": "bun run build:all && electron-builder --dir",
    "dist": "bun run build:all && electron-builder --publish never",
    "dist:win": "bun run build:all && electron-builder --win --publish never",
    "dist:mac": "bun run build:all && electron-builder --mac --publish never",
    "dist:linux": "bun run build:all && electron-builder --linux --publish never"
  },
  "type": "module"
}
