{
  "name": "futureboard-studio",
  "private": true,
  "version": "2026.05.18",
  "description": "Futureboard Studio",
  "author": "Arizkami",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "node scripts/sync-shared-menu.mjs && tsc -p .",
    "dev": "concurrently -k -n tsc,electron -c blue,magenta \"tsc -p . --watch\" \"wait-on dist/main.js && electron .\"",
    "start": "electron .",
    "build:native:audio": "cd ../../frameworks/SphereDirectAudioEngine && cargo build --release --lib && node ../../apps/electron/scripts/copy-native-audio.mjs",
    "build:native:audio:debug": "cd ../../frameworks/SphereDirectAudioEngine && cargo build --lib && node ../../apps/electron/scripts/copy-native-audio.mjs --debug",
    "build:renderer": "bun run --cwd ../web build:electron",
    "copy:renderer": "node scripts/copy-renderer.cjs",
    "build:all": "bun run build:native:audio && bun run build:renderer && bun run build && bun run copy:renderer",
    "pack": "bun run build:all && electron-builder --dir",
    "dist": "bun run build:all && electron-builder --publish never",
    "dist:win": "bun run build:all && electron-builder --win --publish never",
    "dist:mac": "bun run build:all && electron-builder --mac --publish never",
    "dist:linux": "bun run build:all && electron-builder --linux --publish never"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "concurrently": "^9.0.0",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "rcedit": "^5.0.2",
    "typescript": "^6.0.3",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "org.mochilinux.studio",
    "productName": "Futureboard Studio",
    "executableName": "Futureboard Studio",
    "copyright": "Copyright © ${author}",
    "publish": {
      "provider": "github",
      "owner": "arizkami",
      "repo": "Futureboard"
    },
    "afterPack": "scripts/after-pack.cjs",
    "asar": true,
    "asarUnpack": [],
    "compression": "maximum",
    "removePackageScripts": true,
    "removePackageKeywords": true,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "package.json",
      "!**/*.map",
      "!**/*.ts",
      "!**/*.tsbuildinfo"
    ],
    "extraResources": [
      {
        "from": "icons",
        "to": "icons",
        "filter": ["**/*"]
      },
      {
        "from": "resources",
        "to": ".",
        "filter": ["*.node", "*.dll", "*.dylib", "*.so"]
      }
    ],
    "fileAssociations": [
      {
        "ext": "mochiproj",
        "name": "Futureboard Studio Project",
        "description": "Futureboard Studio Project File",
        "role": "Editor",
        "icon": "icons/icon.ico"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "icons/icon.ico",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "shortcutName": "Futureboard Studio",
      "installerIcon": "icons/icon.ico",
      "uninstallerIcon": "icons/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "category": "public.app-category.music",
      "icon": "icons/icon.icns",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "hardenedRuntime": false,
      "identity": null
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        }
      ],
      "category": "AudioVideo;Audio;Music",
      "icon": "icons/app.png",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  }
}
