{
  "name": "futureboard-studio",
  "private": true,
  "version": "2026.05-alpha1",
  "description": "Futureboard Studio",
  "author": "Arizkami",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p .",
    "dev": "concurrently -k -n tsc,electron -c blue,magenta \"tsc -p . --watch\" \"wait-on dist/main.js && electron .\"",
    "start": "electron .",
    "build:renderer": "bun run --cwd ../web build:electron",
    "copy:renderer": "node scripts/copy-renderer.cjs",
    "build:all": "bun run build:renderer && bun run build && bun run copy:renderer",
    "pack": "bun run build:all && electron-builder --dir",
    "dist": "bun run build:all && electron-builder",
    "dist:win": "bun run build:all && electron-builder --win",
    "dist:mac": "bun run build:all && electron-builder --mac",
    "dist:linux": "bun run build:all && electron-builder --linux"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "concurrently": "^9.0.0",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "rcedit": "^5.0.2",
    "typescript": "^6.0.3",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "org.mochilinux.studio",
    "productName": "Futureboard Studio",
    "copyright": "Copyright © ${author}",
    "afterPack": "scripts/after-pack.cjs",
    "asar": true,
    "asarUnpack": [],
    "compression": "maximum",
    "removePackageScripts": true,
    "removePackageKeywords": true,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "package.json",
      "!**/*.map",
      "!**/*.ts",
      "!**/*.tsbuildinfo"
    ],
    "extraResources": [
      {
        "from": "icons",
        "to": "icons",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "icons/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "shortcutName": "Futureboard Studio",
      "installerIcon": "icons/icon.ico",
      "uninstallerIcon": "icons/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "category": "public.app-category.music",
      "icon": "icons/app.png",
      "hardenedRuntime": true
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        }
      ],
      "category": "AudioVideo",
      "icon": "icons/app.png"
    }
  }
}
