{
  "id": "futureboard.template-audio-plugin",
  "displayName": "Template Audio Plugin",
  "publisher": "futureboard",
  "version": "0.1.0",
  "engines": {
    "futureboard": ">=0.1.0"
  },
  "categories": ["Audio", "Effects"],
  "activationEvents": ["onAudioPlugin:template.gain"],
  "main": "./index.ts",
  "contributes": {
    "audioPlugins": [
      {
        "id": "template.gain",
        "name": "Template Gain",
        "vendor": "Futureboard Template",
        "category": "effect",
        "backend": "./src/backend",
        "editor": "./src/editor/App.tsx",
        "params": [
          { "id": "power", "name": "Power", "defaultValue": 1, "min": 0, "max": 1, "unit": "bool" },
          { "id": "gainDb", "name": "Gain", "defaultValue": 0, "min": -24, "max": 24, "unit": "dB" },
          { "id": "mix", "name": "Mix", "defaultValue": 100, "min": 0, "max": 100, "unit": "%" }
        ]
      }
    ]
  }
}
