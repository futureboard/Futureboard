{
  "name": "futureboard-studio",
  "private": true,
  "type": "module",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "crates/*",
      "plugins/*",
      "extensions/template",
      "crates/BuiltinAudioPlugins/crates/meowsyn/editor",
      "crates/BuiltinAudioPlugins/crates/opensampler/editor",
      "crates/BuiltinAudioPlugins/crates/rodharerist/editorui"
    ],
    "catalog": {
      "@dnd-kit/core": "^6.3.1",
      "@dnd-kit/sortable": "^10.0.0",
      "@dnd-kit/utilities": "^3.2.2",
      "@eslint/js": "^10.0.1",
      "@fontsource-variable/ibm-plex-sans": "^5.3.0",
      "@fontsource/ibm-plex-sans": "^5.3.0",
      "@tabler/icons-react": "^3.45.0",
      "@tailwindcss/vite": "^4.3.3",
      "@types/bun": "latest",
      "@types/node": "^26.1.1",
      "@types/react": "^19.2.17",
      "@types/react-dom": "^19.2.3",
      "@vitejs/plugin-react": "^6.0.4",
      "eslint": "^10.7.0",
      "eslint-plugin-react-hooks": "^7.1.1",
      "eslint-plugin-react-refresh": "^0.5.3",
      "globals": "^17.7.0",
      "react": "^19.2.8",
      "react-dom": "^19.2.8",
      "react-router-dom": "^7.18.1",
      "sass": "^1.101.3",
      "tailwindcss": "^4.3.3",
      "typescript": "^7.0.2",
      "typescript-eslint": "^8.65.0",
      "vite": "^8.1.5",
      "vite-plugin-singlefile": "^2.3.3"
    }
  },
  "scripts": {
    "dev:native": "cargo run -p futureboard_native",
    "dev:server": "bun run --cwd apps/server dev",
    "cargo:check": "cargo check --workspace",
    "cargo:build": "cargo build --workspace",
    "cargo:release": "cargo build --workspace --release",
    "cargo:test": "cargo test --workspace",
    "cargo:clippy": "cargo clippy --workspace -- -D warnings",
    "cargo:fmt": "cargo fmt --all",
    "cargo:fmt:check": "cargo fmt --all -- --check",
    "cargo:clean": "cargo clean",
    "build:plugin-editors": "bun run --cwd crates/BuiltinAudioPlugins/crates/equz8/editor build && bun run --cwd crates/BuiltinAudioPlugins/crates/meowsyn/editor build && bun run --cwd crates/BuiltinAudioPlugins/crates/opensampler/editor build && bun run --cwd crates/BuiltinAudioPlugins/crates/rodharerist/editorui build",
    "build:native": "bun run build:plugin-editors && cargo run -p xtask -- package --profile release --edition community --plugin all",
    "build:native:debug": "bun run build:plugin-editors && cargo run -p xtask -- package --profile dev --edition community --plugin all",
    "bundle:native:mac": "bash packaging/native/bundle-macos.sh",
    "bundle:native:mac:dmg": "bash packaging/native/bundle-macos.sh && bash packaging/native/bundle-macos-dmg.sh",
    "bundle:native:win": "pwsh -File packaging/windows/build-installer.ps1",
    "installer:native:win": "bun run build:native && pwsh -File packaging/windows/build-installer.ps1",
    "build:audio:plugins": "cargo check -p sphere-audio-plugins && cargo check --manifest-path extensions/template/Cargo.toml && bun install --cwd extensions/template && bun run --cwd extensions/template typecheck",
    "build:all": "bun run build:native",
    "check": "bun run cargo:check",
    "lint": "bun run cargo:clippy",
    "fmt": "bun run cargo:fmt"
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "sharp": "^0.35.1"
  }
}
