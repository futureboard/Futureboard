{
  "name": "futureboard-studio",
  "private": true,
  "type": "module",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "crates/*",
      "plugins/*",
      "extensions/template",
      "crates/BuiltinAudioPlugins/crates/meowsyn/editor",
      "crates/BuiltinAudioPlugins/crates/opensampler/editor",
      "crates/BuiltinAudioPlugins/crates/rodharerist/editorui"
    ],
    "catalog": {
      "@dnd-kit/core": "^6.3.1",
      "@dnd-kit/sortable": "^10.0.0",
      "@dnd-kit/utilities": "^3.2.2",
      "@eslint/js": "^10.0.1",
      "@fontsource-variable/ibm-plex-sans": "^5.3.0",
      "@fontsource/ibm-plex-sans": "^5.3.0",
      "@tabler/icons-react": "^3.45.0",
      "@tailwindcss/vite": "^4.3.3",
      "@types/bun": "latest",
      "@types/node": "^26.1.1",
      "@types/react": "^19.2.17",
      "@types/react-dom": "^19.2.3",
      "@vitejs/plugin-react": "^6.0.4",
      "eslint": "^10.7.0",
      "eslint-plugin-react-hooks": "^7.1.1",
      "eslint-plugin-react-refresh": "^0.5.3",
      "globals": "^17.7.0",
      "react": "^19.2.8",
      "react-dom": "^19.2.8",
      "react-router-dom": "^7.18.1",
      "sass": "^1.101.3",
      "tailwindcss": "^4.3.3",
      "typescript": "^7.0.2",
      "typescript-eslint": "^8.65.0",
      "vite": "^8.1.5",
      "vite-plugin-singlefile": "^2.3.3"
    }
  },
  "scripts": {
    "dev:web": "bun run --cwd apps/web dev",
    "dev:electron": "concurrently -k -n web,electron \"bun run --cwd apps/web dev\" \"bun run --cwd apps/electron dev\"",
    "dev:native": "cargo run -p futureboard_native",
    "dev:server": "bun run --cwd apps/server dev",
    "cargo:check": "cargo check --workspace",
    "cargo:build": "cargo build --workspace",
    "cargo:release": "cargo build --workspace --release",
    "cargo:test": "cargo test --workspace",
    "cargo:clippy": "cargo clippy --workspace -- -D warnings",
    "cargo:fmt": "cargo fmt --all",
    "cargo:fmt:check": "cargo fmt --all -- --check",
    "cargo:clean": "cargo clean",
    "build:native": "cargo build --release -p futureboard_native",
    "build:native:debug": "cargo build -p futureboard_native",
    "bundle:native:mac": "bash packaging/native/bundle-macos.sh",
    "bundle:native:mac:dmg": "bash packaging/native/bundle-macos.sh && bash packaging/native/bundle-macos-dmg.sh",
    "bundle:native:win": "pwsh -File packaging/windows/build-installer.ps1",
    "installer:native:win": "cargo build --release -p futureboard_native && pwsh -File packaging/windows/build-installer.ps1",
    "build:wasm": "bun run --cwd apps/web build:audio:wasm",
    "build:audio:plugins": "cargo check -p sphere-audio-plugins && cargo check --manifest-path extensions/template/Cargo.toml && bun install --cwd extensions/template && bun run --cwd extensions/template typecheck",
    "build:web": "bun run --cwd apps/web build",
    "build:electron": "bun run build:audio:plugins && bun run --cwd apps/electron build:all",
    "pack:electron": "bun run --cwd apps/electron pack",
    "dist:electron": "bun run --cwd apps/electron dist",
    "dist:electron:win": "bun run --cwd apps/electron dist:win",
    "dist:electron:mac": "bun run --cwd apps/electron dist:mac",
    "dist:electron:linux": "bun run --cwd apps/electron dist:linux",
    "build:all": "bun run build:wasm && bun run build:native && bun run build:electron",
    "check": "bun run cargo:check && bun run --cwd apps/web lint",
    "lint": "bun run cargo:clippy && bun run --cwd apps/web lint",
    "fmt": "bun run cargo:fmt"
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "sharp": "^0.35.1"
  }
}
