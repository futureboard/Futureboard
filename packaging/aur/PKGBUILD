# Maintainer: Arizkami <arizkami@users.noreply.github.com>
pkgname=futureboard-studio-bin
pkgver=2026.5.18
pkgrel=1
pkgdesc="Futureboard Studio — Digital Audio Workstation"
arch=('x86_64')
url="https://github.com/arizkami/Futureboard"
license=('LicenseRef-proprietary')
depends=(
  'alsa-lib'
  'at-spi2-core'
  'gtk3'
  'libnotify'
  'libsecret'
  'libxss'
  'libxtst'
  'nss'
  'xdg-utils'
)
optdepends=(
  'pipewire-pulse: PipeWire audio support'
  'pulseaudio: PulseAudio support'
)
provides=('futureboard-studio')
conflicts=('futureboard-studio')
options=('!strip' '!debug')

_appimage="Futureboard.Studio-${pkgver}-x86_64.AppImage"
source_x86_64=("${_appimage}::https://github.com/arizkami/Futureboard/releases/download/nightly/${_appimage}")
sha256sums_x86_64=('SKIP')

prepare() {
  chmod +x "${srcdir}/${_appimage}"
  "${srcdir}/${_appimage}" --appimage-extract
}

package() {
  # App files
  install -dm755 "${pkgdir}/opt/${pkgname}"
  cp -r "${srcdir}/squashfs-root/"* "${pkgdir}/opt/${pkgname}/"

  # Launcher
  install -dm755 "${pkgdir}/usr/bin"
  cat > "${pkgdir}/usr/bin/futureboard-studio" << 'EOF'
#!/usr/bin/env bash
exec /opt/futureboard-studio-bin/futureboard-studio "$@"
EOF
  chmod +x "${pkgdir}/usr/bin/futureboard-studio"

  # Desktop entry
  install -dm755 "${pkgdir}/usr/share/applications"
  cat > "${pkgdir}/usr/share/applications/futureboard-studio.desktop" << EOF
[Desktop Entry]
Name=Futureboard Studio
Comment=Digital Audio Workstation
Exec=futureboard-studio %U
Icon=futureboard-studio
Type=Application
Categories=AudioVideo;Audio;Music;
MimeType=application/x-mochiproj;
StartupWMClass=futureboard-studio
EOF

  # Icons (extract from AppImage resources)
  for size in 16 32 48 64 128 256 512; do
    local icon_src="${srcdir}/squashfs-root/usr/share/icons/hicolor/${size}x${size}/apps/futureboard-studio.png"
    if [[ -f "${icon_src}" ]]; then
      install -Dm644 "${icon_src}" \
        "${pkgdir}/usr/share/icons/hicolor/${size}x${size}/apps/futureboard-studio.png"
    fi
  done

  # Fallback: single-size icon from AppImage root
  local root_icon="${srcdir}/squashfs-root/futureboard-studio.png"
  if [[ -f "${root_icon}" ]]; then
    install -Dm644 "${root_icon}" \
      "${pkgdir}/usr/share/icons/hicolor/512x512/apps/futureboard-studio.png"
  fi
}
